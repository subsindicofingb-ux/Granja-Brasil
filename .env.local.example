NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Produção (sem hífen): https://granjabrasil.app.br

# Estabiliza IDs das Server Actions entre deploys (obrigatório na Vercel em produção)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Chave para criptografar senhas dos equipamentos ControlID (server only)
ACCESS_DEVICE_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Worker de sync ControlID (server only)
ACCESS_SYNC_WORKER_SECRET=change-me-to-another-long-random-secret
# Limita sync aos equipamentos marcados como piloto (false = todos os equipamentos ativos)
ACCESS_SYNC_PILOT_ONLY=false
# Portaria: false = fila para o síndico aprovar; true = cadastra e libera ControlID na hora
DOORMAN_REGISTRATION_AUTO_FULFILL=true
# URL pública do app para disparar o worker em background (produção: https://granjabrasil.app.br)
ACCESS_SYNC_SITE_URL=http://localhost:3000

# Cron automático (/api/access-sync/process) exige Vercel Pro (Hobby: use o botão Sincronizar na ficha do morador).
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Granja Brasil <contato@granjabrasil.app.br>
RESEND_REPLY_TO_EMAIL=contato@granjabrasil.app.br
